{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "nodejs@22.12.0"
  ],
  "shell": {
    "init_hook": [
      "npm ci"
    ],
    "scripts": {
      "build": [
        "npm run build"
      ],
      "dev": [
        "npm run dev"
      ],
      "lint": [
        "npm run lint"
      ]
    }
  }
}